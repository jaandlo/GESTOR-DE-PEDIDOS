# VARIABLES DE ENTORNO - FRONTEND
REACT_APP_API_URL=http://localhost:3000/api
REACT_APP_API_TIMEOUT=5000

# VARIABLES DE ENTORNO - BACKEND
# Copiar a .env y actualizar con valores reales

# Base de datos
DATABASE_URL=postgresql://user:password@localhost:5432/gestor_pedidos
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=gestor_pedidos
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password

# Autenticación
JWT_SECRET=tu_secreto_jwt_muy_seguro_aqui
JWT_EXPIRES_IN=24h

# Servidor
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:8000

# Base de datos alternativa (si usas MongoDB)
MONGODB_URI=mongodb://localhost:27017/gestor_pedidos

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Email (opcional - para notificaciones)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Almacenamiento de archivos (opcional)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
AWS_BUCKET=gestor-pedidos

# Aplicación
APP_NAME=Gestor de Pedidos
APP_VERSION=1.0.0
APP_ENVIRONMENT=development
